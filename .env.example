# Selvedge Environment Variables
# Copy to .env.local and fill in values

# Anthropic Claude API - Required for AI fabric analysis
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API (optional - backup for vision)
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# Grok API (optional - alternative model)
# Get your key at: https://x.ai/api
GROK_API_KEY=

# Supabase Database
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog Analytics
# Get from: https://posthog.com/docs/getting-started
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
