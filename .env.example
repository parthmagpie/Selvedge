# Selvedge Environment Variables
# Copy to .env.local and fill in values

# Google Gemini API - Required for AI fabric analysis (primary)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Grok API (fallback for fabric analysis)
# Get your key at: https://x.ai/api
GROK_API_KEY=

# Supabase Database
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PostHog Analytics
# Get from: https://posthog.com/docs/getting-started
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe Payment
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SITE_URL=https://selvedge.draftlabs.org
